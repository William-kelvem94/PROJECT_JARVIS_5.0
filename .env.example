# JARVIS 5.0 - Arquivo .env Exemplo (PT-BR)
# Copie para .env e preencha suas chaves!

# LiveKit (OBRIGATÓRIO para agente voz/video)
LIVEKIT_URL=wss://your-project.livekit.cloud  # ou http://localhost:7880 para local
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Google Gemini (OBRIGATÓRIO para IA realtime)
GOOGLE_API_KEY=AIzaSy...  # ou GEMINI_API_KEY (unifica para GOOGLE)

# Opcionais
OPENROUTER_API_KEY=sk-or-...
FRONTEND_URL=http://localhost:3000

# Desenvolvimento
JARVIS_FULL_PERCEPTION=0  # 1=instala heavy deps (deepface/face_recognition)
JARVIS_NO_PERCEPTION=0    # Desabilita MediaPipe se CPU fraca

