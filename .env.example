# .env.example para JARVIS 5.0
# Copie para .env e preencha valores reais

# LiveKit (obrigatório)
LIVEKIT_URL=ws://your-livekit-server:7880
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Google Gemini (opcional, fallback OpenAI)
GEMINI_API_KEY=your_gemini_key

# OpenAI (opcional)
OPENAI_API_KEY=your_openai_key

# Knowledge Base (Obsidian)
JARVIS_KB_PATH=D:\OBSIDIAN\Will\Projetos\Privados\PROJECT_JARVIS_5.0-KnowledgeBase
JARVIS_VAULT_ROOT=D:\OBSIDIAN\Will

# Backend
DEBUG=true
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_LIVEKIT_URL=http://localhost:7880
NEXT_PUBLIC_WS_URL=ws://localhost:7880

