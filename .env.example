# .env.example para JARVIS 5.0
# Copie para .env e preencha valores reais

# 🧠 Brain Router (Opcional - para processamento local)
LM_STUDIO_URL=http://localhost:1234/v1

# 🔑 API Keys
GOOGLE_API_KEY=sua_chave_gemini_aqui
# OPENAI_API_KEY=sua_chave_openai_aqui

# Google Gemini (opcional, fallback OpenAI)
GEMINI_API_KEY=your_gemini_key

# OpenAI (opcional)
OPENAI_API_KEY=your_openai_key

# Knowledge Base (Obsidian)
JARVIS_KB_PATH=D:\OBSIDIAN\Will\Projetos\Privados\PROJECT_JARVIS_5.0-KnowledgeBase
JARVIS_VAULT_ROOT=D:\OBSIDIAN\Will

# Backend
DEBUG=true
LOG_LEVEL=INFO

# AI Device Configuration
# Auto-detect: cuda if available, else cpu
# Force CPU: set to "cpu"
JARVIS_AI_DEVICE=auto

# Whisper Model Size (tiny, base, small)
JARVIS_WHISPER_MODEL=tiny

# Thread Limit for CPU (to prevent overheating on laptops)
JARVIS_CPU_THREADS=4

# Memory Management
JARVIS_ENABLE_GC=true

# Frontend (Native WebSocket)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/voice-stream
