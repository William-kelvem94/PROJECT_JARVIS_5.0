{
  "voice": {
    "rate": 160,
    "volume": 0.85,
    "language": "pt-BR",
    "use_gtts": true,
    "pitch": 45,
    "voice_id": "pt-BR-Wavenet-A"
  },
  "recognition": {
    "timeout": 8,
    "phrase_limit": 15,
    "energy_threshold": 300,
    "dynamic_energy_threshold": true
  },
  "system": {
    "os": "auto",
    "debug_mode": false,
    "log_level": "INFO"
  },
  "commands": {
    "wake_word": null,
    "exit_phrases": ["sair", "tchau", "até logo"],
    "help_phrases": ["ajuda", "help", "comandos"]
  },
  "natural_speech": {
    "use_fillers": true,
    "use_hesitations": true,
    "use_breathing": true,
    "emotion_detection": true,
    "conversation_flow": true,
    "prosody_enhancement": true,
    "syllable_emphasis": true,
    "natural_pauses": true
  },
  "local_voice": {
    "use_local_tts": true,
    "preferred_engine": "auto",
    "coqui_model": "tts_models/multilingual/multi-dataset/xtts_v2",
    "espeak_voice": "pt-br",
    "festival_voice": "default",
    "emotion_intensity": 0.8,
    "speaking_style": "natural"
  },
  "cloud_voice": {
    "use_cloud_tts": true,
    "prefer_microsoft": true,
    "prefer_google": false,
    "max_daily_requests": 1000,
    "enable_security": true,
    "timeout_seconds": 30,
    "chunk_size": 200,
    "fallback_enabled": true
  },
  "security": {
    "validate_urls": true,
    "use_https_only": true,
    "trusted_domains": [
      "translate.google.com",
      "speech.platform.bing.com",
      "texttospeech.googleapis.com"
    ],
    "max_file_size_mb": 10,
    "scan_downloads": false
  }
}
