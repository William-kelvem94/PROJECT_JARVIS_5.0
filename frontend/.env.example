# Configuracao do Jarvis Native
# Deixe vazio para usar o proxy interno do Next.
# API principal: /jarvis-api -> http://localhost:8000
# Telemetria padrao: /jarvis-api/telemetry -> backend principal, com /status e /history.
NEXT_PUBLIC_JARVIS_API_URL=
NEXT_PUBLIC_TELEMETRY_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: dashboard legado de telemetria na porta 8001.
# Use somente para telas que dependem de /api/status; ele nao expoe /history.
# JARVIS_TELEMETRY_URL=http://localhost:8001
# NEXT_PUBLIC_TELEMETRY_URL=/jarvis-telemetry/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/voice
