# JARVIS 5.0 - Professional .gitignore

# -----------------------------------------------------------------------------
# SYSTEM & ENVIRONMENT
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
env/
ENV/
.venv

# OS Generated
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# IDE & EDITOR
# -----------------------------------------------------------------------------
.idea/
.vscode/launch.json
.vscode/tasks.json
# Keep .vscode/settings.json and extensions.json if shared
# .cursor/ is kept for context rules

# -----------------------------------------------------------------------------
# CONFIGURATION & SECRETS (CRITICAL)
# -----------------------------------------------------------------------------
.env
config/secrets.yaml
*.key
*.pem
*.pfx

# -----------------------------------------------------------------------------
# DATA STORAGE & LOGS
# -----------------------------------------------------------------------------
*.log
data/logs/*
!data/logs/.gitkeep

# Memory / Database
data/memory/chroma.sqlite3
data/memory/*.parquet
data/memory/*
!data/memory/.gitkeep

# Sync / Backup
data/sync/
data/backup/
data/temp/

# -----------------------------------------------------------------------------
# MEDIA & ASSETS (GENERATED)
# -----------------------------------------------------------------------------
*.wav
*.mp3
*.png
*.jpg
*.jpeg
*.gif
*.mp4

# -----------------------------------------------------------------------------
# AI MODELS (LARGE FILES)
# -----------------------------------------------------------------------------
models/*.pt
models/*.bin
models/*.gguf
models/*.safetensors
!models/vision/yolov8n.pt  # Keep small reference models if needed

# -----------------------------------------------------------------------------
# TESTING & COVERAGE
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# LEGACY & MIGRATION
# -----------------------------------------------------------------------------
archive/
_backup_legacy/
*.bak
migration_report.json
ollama_setup.exe
