# JARVIS 5.0 - Professional .gitignore

# -----------------------------------------------------------------------------
# SYSTEM & ENVIRONMENT
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environment
venv/
env/
ENV/
.venv

# OS Generated
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
# VSCode
.vscode/

# Logs
logs/
*.log
*.txt

# Dados temporários
data/cache/
data/temp/
data/audio/temp/

# Modelos
models/trained/
models/yolo/

# Outros
.env
.idea/

# -----------------------------------------------------------------------------
# IDE & EDITOR
# -----------------------------------------------------------------------------
.idea/
.vscode/launch.json
.vscode/tasks.json
# Keep .vscode/settings.json and extensions.json if shared
# .cursor/ is kept for context rules

# -----------------------------------------------------------------------------
# CONFIGURATION & SECRETS (CRITICAL)
# -----------------------------------------------------------------------------
.env
config/secrets.yaml
*.key
*.pem
*.pfx

# -----------------------------------------------------------------------------
# DATA STORAGE & LOGS
# -----------------------------------------------------------------------------
*.log
data/logs/*
!data/logs/.gitkeep

# Memory / Database
data/memory/*
!data/memory/.gitkeep

# Sync / Backup
data/sync/
data/backup/
data/temp/

# -----------------------------------------------------------------------------
# MEDIA & ASSETS (GENERATED)
# -----------------------------------------------------------------------------
# Audio (typically generated)
*.wav
*.mp3

# Generated images and videos under data/ and temp-like directories
data/**/*.png
data/**/*.jpg
data/**/*.jpeg
data/**/*.gif
data/**/*.mp4
# End MEDIA & ASSETS (GENERATED) section
# -----------------------------------------------------------------------------
# AI MODELS (LARGE FILES)
# -----------------------------------------------------------------------------
models/*.pt
models/*.bin

models/*.safetensors
!models/vision/yolov8n.pt  # Keep small reference models if needed
models/*.h5
models/*.pb
models/*.onnx

# -----------------------------------------------------------------------------
# TESTING & COVERAGE
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# PYTHON SPECIFIC
# -----------------------------------------------------------------------------
.python-version
.mypy_cache/
.dmypy.json
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# LEGACY & MIGRATION
# -----------------------------------------------------------------------------
archive/
_backup_legacy/
*.bak
migration_report.json
ollama_setup.exe
