{
    "include": [
        "backend",
        "config"
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        "**/frontend",
        "**/__pyrefly_virtual__/**"
    ],
    "executionEnvironments": [
        {
            "root": ".",
            "extraPaths": [
                "backend/app",
                "backend"
            ]
        }
    ],
    "venvPath": ".",
    "venv": ".venv",
    "typeCheckingMode": "basic",
    "reportMissingImports": "warning",
    "reportGeneralTypeIssues": "warning",
    "reportUndefinedVariable": "warning"
}